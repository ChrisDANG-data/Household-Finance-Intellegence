{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "predev": "node ../../scripts/check-node.mjs && node scripts/ensure-ffmpeg.mjs",
    "dev": "next dev --hostname 0.0.0.0 --port 3000",
    "build": "npm exec prisma -- generate && next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "npm exec prisma -- generate",
    "db:generate": "npm exec prisma -- generate",
    "db:migrate": "npm exec prisma -- migrate dev",
    "db:push": "npm exec prisma -- db push",
    "db:studio": "npm exec prisma -- studio",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@base-ui/react": "^1.5.0",
    "@tailwindcss/oxide-win32-x64-msvc": "4.3.0",
    "@xenova/transformers": "^2.17.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "ffmpeg-static": "^5.3.0",
    "lightningcss-win32-x64-msvc": "1.32.0",
    "lucide-react": "^1.16.0",
    "mupdf": "^1.27.0",
    "next": "16.2.6",
    "pdf-parse": "^1.1.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-plaid-link": "^4.1.1",
    "shadcn": "^4.8.0",
    "tailwind-merge": "^3.6.0",
    "tesseract.js": "^6.0.1",
    "tw-animate-css": "^1.4.0",
    "wavefile": "^11.0.0"
  },
  "devDependencies": {
    "@prisma/client": "^6.19.3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "nanoid": "^3.3.12",
    "picocolors": "^1.1.1",
    "prisma": "^6.19.3",
    "source-map-js": "^1.2.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
